@page
@model dynamic
<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Linker</title>
  </head>
  <body style="background:#111;color:#fff;font-family:Arial,sans-serif;padding:24px;">
    <h1>Linker Beta</h1>
    <p>This is a minimal .NET 9 frontend. Example call to the Next.js backend:</p>
    <pre id="out">Loading...</pre>
    <script>
      fetch('/api/proxy/api/health').then(r=>r.text()).then(t=>document.getElementById('out').innerText = t).catch(e=>document.getElementById('out').innerText = String(e));
    </script>
  </body>
</html>